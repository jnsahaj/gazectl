#!/usr/bin/env node

const { spawnSync } = require('child_process');
const path = require('path');
const fs = require('fs');

const args = process.argv.slice(2);
const os = process.platform;
const rootDir = path.resolve(__dirname, '..');

if (os === 'darwin') {
  const binPath = path.join(__dirname, 'gazectl-bin');
  const result = spawnSync(binPath, args, { stdio: 'inherit' });
  process.exit(result.status || 0);
} else {
  // Linux or Windows: Use Python
  let pyCmd = 'python3';
  if (os === 'win32') {
    pyCmd = 'python'; // Typically `python` on Windows
  }

  // Check if python is available
  const checkPython = spawnSync(pyCmd, ['--version'], { stdio: 'ignore' });
  if (checkPython.error) {
    pyCmd = 'python'; // fallback to python
    const checkPython2 = spawnSync(pyCmd, ['--version'], { stdio: 'ignore' });
    if (checkPython2.error) {
      console.error(`Error: Python could not be found. gazectl requires Python 3 on Linux/Windows.`);
      process.exit(1);
    }
  }

  const pyScript = path.join(rootDir, 'gazectl.py');
  const result = spawnSync(pyCmd, [pyScript, ...args], { stdio: 'inherit' });
  process.exit(result.status || 0);
}
