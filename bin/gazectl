#!/usr/bin/env node

const { spawnSync } = require('child_process');
const path = require('path');
const fs = require('fs');

const args = process.argv.slice(2);
const os = process.platform;
const rootDir = path.resolve(__dirname, '..');

function handleSpawnResult(result) {
  if (result.error) {
    console.error(`Error executing process: ${result.error.message}`);
    process.exit(1);
  }
  if (result.signal) {
    console.error(`Process terminated by signal: ${result.signal}`);
    process.exit(128); // Standard signal exit convention
  }
  process.exit(result.status !== null ? result.status : 1);
}

if (os === 'darwin') {
  const binPath = path.join(__dirname, 'gazectl-bin');
  const result = spawnSync(binPath, args, { stdio: 'inherit' });
  handleSpawnResult(result);
} else {
  // Linux or Windows: Use Python
  let candidates = [];
  if (os === 'win32') {
    candidates = [
      { cmd: 'py', args: ['-3'] },
      { cmd: 'python3', args: [] },
      { cmd: 'python', args: [] }
    ];
  } else {
    candidates = [
      { cmd: 'python3', args: [] },
      { cmd: 'python', args: [] }
    ];
  }

  let finalCmd = null;
  let finalBaseArgs = [];

  for (const { cmd, args: baseArgs } of candidates) {
    const checkResult = spawnSync(cmd, [...baseArgs, '--version'], { encoding: 'utf8' });
    if (!checkResult.error && checkResult.status === 0) {
      // Python outputs version to stdout (3.4+) or stderr (2.x)
      const output = (checkResult.stdout || '') + (checkResult.stderr || '');
      if (output.includes('Python 3.')) {
        finalCmd = cmd;
        finalBaseArgs = baseArgs;
        break;
      }
    }
  }

  if (!finalCmd) {
    console.error(`Error: Python 3 could not be found. gazectl requires Python 3 on Linux/Windows.`);
    process.exit(1);
  }

  const pyScript = path.join(rootDir, 'gazectl.py');
  const result = spawnSync(finalCmd, [...finalBaseArgs, pyScript, ...args], { stdio: 'inherit' });
  handleSpawnResult(result);
}
